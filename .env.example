# ==========================================
# Application
# ==========================================
APP_NAME=Real-Time Fraud Detection System
APP_VERSION=1.0.0
DEBUG=True

# ==========================================
# FastAPI
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=frauddb
POSTGRES_USER=frauduser
POSTGRES_PASSWORD=your_password

DATABASE_URL=postgresql://frauduser:your_password@localhost:5432/frauddb

# ==========================================
# Kafka
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_GROUP_ID=fraud-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest

# ==========================================
# Machine Learning
# ==========================================
MODEL_PATH=models/streaming_fraud_model.pkl

# ==========================================
# Dashboard
# ==========================================
REFRESH_INTERVAL=5